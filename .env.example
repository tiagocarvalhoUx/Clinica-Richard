# Copie este arquivo para frontend/.env e preencha com o Web App do Firebase.
# Firebase Console > Configuracoes do projeto > Seus apps > SDK setup and configuration.
# O login sem senha usa Firebase Authentication com Email Link.
# Nao use RESEND ou SMTP para este fluxo.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

VITE_SITE_URL=http://localhost:3000
VITE_WHATSAPP_NUMBER=5518999999999
VITE_CLINICA_TELEFONE=+55 (18) 98157-3968
VITE_CLINICA_EMAIL=contato@clinicadrrichard.com.br
VITE_CLINICA_ENDERECO=Rua Pedro de Toledo, 737 - Jardim Brasilia, Aracatuba-SP
